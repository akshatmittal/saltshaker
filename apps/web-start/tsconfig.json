{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "declaration": false,
    "noEmit": true,
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": ["node_modules", ".output", ".tanstack"]
}

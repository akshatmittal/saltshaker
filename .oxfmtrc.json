{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "singleAttributePerLine": true,
  "trailingComma": "all",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "sortPackageJson": false,
  "sortTailwindcss": {
    "stylesheet": "apps/web-start/src/styles.css",
    "functions": ["cn", "cva"]
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/coverage/**",
    "**/.pnpm-store/**",
    "**/.output/**",
    "**/.tanstack/**",
    "pnpm-lock.yaml",
    "**/worker-configuration.d.ts",
    "**/routeTree.gen.ts"
  ],
  "overrides": [
    {
      "files": ["*.json", "*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ]
}

{
  "name": "saltshaker-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:app": "turbo build --filter='@workspace/web-start'",
    "build:lib": "turbo build --filter='!@workspace/*'",
    "changeset": "changeset",
    "dev": "turbo dev",
    "dev:lib": "turbo dev --filter='!@workspace/*'",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "release": "changeset publish",
    "typecheck": "turbo typecheck",
    "version": "changeset version",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@workspace/typescript-config": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "^2.9.3",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  }
}

{
  "name": "@akshatmittal/saltshaker",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "viem": "catalog:"
  },
  "devDependencies": {
    "@webgpu/types": "catalog:",
    "@workspace/typescript-config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vitest": "^4.1.2"
  }
}
